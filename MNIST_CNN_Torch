    class ModelTrainer:
        """模型训练器"""
        
        def __init__(self, model, device, learning_rate=0.001):
            self.model = model   # 将传入的模型、设备和学习率保存为实例属性
            self.device = device
            self.learning_rate = learning_rate

            # 损失函数：交叉熵损失（适用于多分类）
            self.criterion = nn.CrossEntropyLoss()   # 适用于 多分类任务，输入是未归一化的 logits，输出是类别标签（整数），自动包含 softmax 和负对数似然计算

            # 优化器：Adam（自适应学习率）
            self.optimizer = optim.Adam(
                model.parameters(),  # 优化器作用于模型的所有可训练参数
                lr=learning_rate,
                weight_decay=1e-5  # 添加 L2 正则化（权重衰减），防止过拟合
            )

            # 学习率调度器：使用 StepLR 调度器，在每经过 step_size=5 个 epoch 后，将学习率乘以 gamma=0.5，更稳定地收敛
            self.scheduler = optim.lr_scheduler.StepLR(
                self.optimizer, 
                step_size=5,      # 每5个epoch
                gamma=0.5         # 学习率乘以0.5
            )

            # 记录训练历史
            self.history = {
                'train_loss': [], # 每个 epoch 的训练损失
                'val_loss': [],   # 验证集上的损失
                'train_acc': [],  # 训练集准确率
                'val_acc': [],    # 验证集准确率
                'learning_rates': []  # 每个 epoch 的当前学习率（可用于绘图分析）
            }

            # 最佳模型跟踪
            self.best_val_acc = 0.0
            self.best_model_state = None

        def train_epoch(self, train_loader, epoch, num_epochs):
            """训练一个epoch"""
            self.model.train()
            running_loss = 0.0
            correct = 0
            total = 0

            # 进度条
            pbar = tqdm(train_loader, desc=f'Epoch {epoch+1}/{num_epochs}')

            for batch_idx, (inputs, targets) in enumerate(pbar):
                # 移将 inputs 和 targets 移动到指定的设备（如 GPU）上，以进行后续的计算。
                inputs, targets = inputs.to(self.device), targets.to(self.device)

                # 将 inputs 通过模型 self.model 进行前向传播，得到模型的输出 outputs
                # 使用损失函数 self.criterion 计算 outputs 和 targets 之间的损失值 loss
                outputs = self.model(inputs)
                loss = self.criterion(outputs, targets)

                # 调用 self.optimizer.zero_grad() 清除之前的梯度
                # 调用 loss.backward() 进行反向传播，计算每个参数的梯度
                self.optimizer.zero_grad()
                loss.backward()

                # 梯度裁剪（防止梯度爆炸）
                torch.nn.utils.clip_grad_norm_(self.model.parameters(), max_norm=1.0)

                # 更新参数
                self.optimizer.step()

                # 统计
                # 累加当前批次的损失值 loss.item() 到 running_loss
                # 获取 outputs 中每个样本的最大值的索引 predicted，作为预测结果
                # 累加当前批次的样本数量到 total
                # 比较 predicted 和 targets，统计预测正确的样本数量，并累加到 correct
                running_loss += loss.item()
                _, predicted = outputs.max(1)
                total += targets.size(0)
                correct += predicted.eq(targets).sum().item()

                # 更新进度条
                pbar.set_postfix({
                    'Loss': f'{loss.item():.4f}',
                    'Acc': f'{100.*correct/total:.2f}%'
                    })
                
             # 计算平均损失和准确率
            epoch_loss = running_loss / len(train_loader)
            epoch_acc = 100. * correct / total

            return epoch_loss, epoch_acc
        
        def validate(self, val_loader):
            """验证模型"""
            self.model.eval() # 将模型设置为评估模式，这通常会关闭 dropout 和 batch normalization 等在训练时启用但在评估时不需要的层。
            val_loss = 0.0
            correct = 0
            total = 0

            with torch.no_grad():  # 禁用梯度计算可以节省内存并加速计算，因为验证过程中不需要反向传播
                for inputs, targets in val_loader:
                    inputs, targets = inputs.to(self.device), targets.to(self.device)
                    outputs = self.model(inputs)
                    loss = self.criterion(outputs, targets)

                    val_loss += loss.item()  # 将当前批次的损失值加到 val_loss 上
                    _, predicted = outputs.max(1) # 找到每个样本输出的最大值的索引（即预测类别）
                    total += targets.size(0) # 累计总样本数
                    correct += predicted.eq(targets).sum().item() # 比较预测类别 predicted 和实际目标 targets，累计正确预测的数量

            val_loss = val_loss / len(val_loader)
            val_acc = 100. * correct / total

            return val_loss, val_acc
        
        def train(self, train_loader, val_loader, num_epochs=1):
            """完整训练过程"""
            print(f"\n开始训练模型...")
            print(f"设备: {self.device}")
            print(f"优化器: Adam (lr={self.learning_rate})")
            print(f"学习率调度: StepLR (step=5, gamma=0.5)")
            print(f"正则化: L2 weight_decay=1e-5")
            print(f"总epoch数: {num_epochs}")
            print("="*60)
            
            start_time = time.time()

            for epoch in range(num_epochs):
                # 训练一个epoch
                train_loss, train_acc = self.train_epoch(train_loader, epoch, num_epochs)
                
                # 验证
                val_loss, val_acc = self.validate(val_loader)
                
                # 记录历史
                self.history['train_loss'].append(train_loss)
                self.history['train_acc'].append(train_acc)
                self.history['val_loss'].append(val_loss)
                self.history['val_acc'].append(val_acc)
                self.history['learning_rates'].append(self.optimizer.param_groups[0]['lr'])

                # 保存最佳模型
                if val_acc > self.best_val_acc:
                    self.best_val_acc = val_acc
                    self.best_model_state = self.model.state_dict().copy()

                    # 保存模型到文件
                    torch.save({
                        'epoch': epoch,
                        'model_state_dict': self.model.state_dict(),
                        'optimizer_state_dict': self.optimizer.state_dict(),
                        'val_acc': val_acc,
                        'history': self.history
                    }, 'best_digit_recognizer.pth')

                # 更新学习率
                self.scheduler.step()

                # 打印epoch结果
                print(f"\nEpoch {epoch+1}/{num_epochs} 完成:")
                print(f"  训练损失: {train_loss:.4f}, 训练准确率: {train_acc:.2f}%")
                print(f"  验证损失: {val_loss:.4f}, 验证准确率: {val_acc:.2f}%")
                print(f"  最佳验证准确率: {self.best_val_acc:.2f}%")
                print(f"  当前学习率: {self.optimizer.param_groups[0]['lr']:.6f}")
                print("-"*50)

            # 训练完成
            end_time = time.time()
            training_time = end_time - start_time

            print(f"\n训练完成!")
            print(f"总训练时间: {training_time:.2f}秒")
            print(f"平均每个epoch: {training_time/num_epochs:.2f}秒")
            print(f"最佳验证准确率: {self.best_val_acc:.2f}%")

            # 加载最佳模型
            if self.best_model_state is not None:
                self.model.load_state_dict(self.best_model_state)
                print("已加载最佳模型权重")

            return self.history
        
    # 创建训练器并开始训练
    trainer = ModelTrainer(model, device, learning_rate=0.001)
    history = trainer.train(train_loader, val_loader, num_epochs=1)


