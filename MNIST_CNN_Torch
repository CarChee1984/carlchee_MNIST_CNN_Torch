    class MNISTDataLoader:
        def __init__(self,batch_size=64):
            self.batch_size=batch_size
            # 构造函数 __init__初始化方法,每次从数据集中读取一批（batch）样本

            self.transform=transforms.Compose(  
                    #transforms.Compose 将多个变换操作组合成一个流程，按顺序执行
                [
                    transforms.ToTensor(),
                    transforms.Normalize((0.1307,),(0.3081,))
                    # # 标准化,目的是让输入数据分布更接近标准正态分布，有助于模型更快收敛。
                    # MNIST数据集的均值和标准差是已知的 output=(input-mean[0.1307]/std[0.3081])
                ]
            )
        
        def load_data(self):
            print("正在下载MNIST数据集...")

            # 下载训练集
            train_dataset=torchvision.datasets.MNIST(
                root='./data/cnn_mnist_torch',  # 数据保存路径
                train=True,     # 训练集
                download=True,  # 如果不存在则下载
                transform=self.transform # 应用预处理
            )

            # 下载测试集
            test_dataset=torchvision.datasets.MNIST(
                root='./data/cnn_mnist_torch',
                train=False,  # 测试集
                download=True,
                transform=self.transform
            )

            print(f"训练集大小：{len(train_dataset)}")
            print(f"测试集大小：{len(test_dataset)}")

            # 划分训练集和验证集（80%训练，20%验证）
            train_size=int(0.8*len(train_dataset))
            val_size=len(train_dataset)-train_size  
            # 不能直接用0.2，会导致数据重复
            train_dataset,val_dataset = random_split(
                train_dataset,[train_size,val_size]
            ) # 右侧train_dataset是原始数据，拆分后覆盖左侧

            print(f"训练集：{len(train_dataset)}个样本")
            print(f"验证集：{len(val_dataset)}个样本")
            print(f"测试集：{len(test_dataset)}个样本")

            # 创建数据加载器
            train_loader=DataLoader(
                train_dataset,
                batch_size=self.batch_size,
                shuffle=True,  # 打乱顺序，提高泛化能力
                num_workers=2  
            )

            val_loader=DataLoader(
                val_dataset,
                batch_size=self.batch_size,
                shuffle=False, # 不打乱，保证评估一致性，便于比较性能。
                num_workers=2
            )

            test_loader=DataLoader(
                test_dataset,
                batch_size=self.batch_size,
                shuffle=False, # 不打乱，保证可复现性。
                num_workers=2
            )

            return train_loader,val_loader,test_loader
    
    # 使用数据加载器
    data_loader=MNISTDataLoader(batch_size=64)
    train_loader,val_loader,test_loader = data_loader.load_data()  

    # 探索数据集
    def explore_dataset(train_loader):
        '''
        探索数据集特征
        '''
        # 获取一个批次的数据
        data_iter=iter(train_loader)   # 创建一个迭代器
        images,labels=next(data_iter)
        '''
        从迭代器中取出第一个批次的数据
        images: 一批图像张量，形状通常是 [batch_size, channels, height, width]
        labels: 对应这批图像的标签张量，形状通常是 [batch_size]
        '''
        print("\n" + "="*60)
        print("数据集探索")
        print("="*60)

        print(f"图像张量形状：{images.shape}")  # shape返回张量在每个维度上的尺寸大小
        print(f"标签张量形状: {labels.shape}")
        print(f"像素值范围: [{images.min():.3f}, {images.max():.3f}]")
        print(f"标签值范围: [{labels.min()}, {labels.max()}]")

        # 检查批次中的标签分布
        '''
        labels 是一个 PyTorch 张量，通常是一维的，比如 [2, 1, 0, 2, 3, 1]，表示每张图像的类别。
        unique: 所有不重复的标签值（如 [0, 1, 2, 3]）
        counts: 对应每个标签出现的次数（如 [1, 2, 2, 1]）
        '''
        unique, counts = torch.unique(labels, return_counts=True)
        print(f"当前批次标签分布:")
        for label, count in zip(unique, counts):
            print(f"数字 {label.item()}: {count}个")
        '''
        使用 zip(unique, counts) 将标签和对应的计数一一配对遍历
        因为 label 是一个标量张量，需要用 .item() 提取其 Python 原始数值。
        '''
        return images, labels

    images,labels=explore_dataset(train_loader)

