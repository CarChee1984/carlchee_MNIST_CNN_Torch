    class ModelManager:
        """模型管理器：负责保存、加载和管理模型"""
        
        @staticmethod
        # model: PyTorch 模型对象
        # optimizer: 优化器对象
        # history: 训练过程中的历史记录
        # filepath: 保存路径
        def save_model(model, optimizer, history, filepath='digit_recognizer_full.pth'):
            """保存完整模型"""
            checkpoint = {
                'model_state_dict': model.state_dict(),   # 'model_state_dict'	模型参数（权重）的字典，可恢复模型结构和参数
                'optimizer_state_dict': optimizer.state_dict(), # 'optimizer_state_dict'	优化器的状态（如动量、学习率等），用于恢复训练状态。
                'history': history, # 'history'	训练过程中的指标（如 loss、acc），便于后续分析。
                'model_architecture': str(model), # 'model_architecture'模型结构的字符串表示（如 str(model)），可用于记录模型结构。
                'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S'), # 'timestamp'保存时间戳，方便追踪版本。
                'test_accuracy': test_results['accuracy'] if 'test_results' in globals() else None # 'test_accuracy'测试集上的准确率（如果存在），否则为 None。
            }
            
            torch.save(checkpoint, filepath)
            print(f"模型已保存到: {filepath}")
            print(f"文件大小: {os.path.getsize(filepath) / 1024:.1f} KB")

        @staticmethod
        def load_model(filepath, model_class=DigitRecognizerCNN, device='cpu'):
            """加载模型"""
            if not os.path.exists(filepath):  # os.path.exists() 检查文件路径是否存在
                raise FileNotFoundError(f"模型文件不存在: {filepath}")
            
            checkpoint = torch.load(filepath,weights_only=False,map_location=device) # map_location=device：将模型数据映射到指定设备（如 "cpu" 或 "cuda"），避免因设备不匹配导致错误。
        
            
            # 创建模型实例
            model = model_class().to(device) # model_class()：实例化传入的模型类（如 DigitRecognizerCNN），得到一个模型对象，.to(device)：将模型移到指定设备（CPU/GPU）
            model.load_state_dict(checkpoint['model_state_dict']) # load_state_dict(...)：从 checkpoint 的 "model_state_dict" 键中取出模型参数字典，并加载到实例化的模型中，完成模型权重的恢复。
            
            print(f"模型已加载: {filepath}")
            print(f"保存时间: {checkpoint.get('timestamp', '未知')}")
            print(f"测试准确率: {checkpoint.get('test_accuracy', '未知')}")
            
            return model, checkpoint
        
        @staticmethod
        def export_to_onnx(model, input_size=(1, 1, 28, 28), filepath='digit_recognizer.onnx'):
            """导出为ONNX格式（便于跨平台部署）"""

            # 创建示例输使用 torch.randn() 创建一个随机张量作为“虚拟输入”（dummy input），其形状与 input_size 一致
            # 这个 dummy_input 是 PyTorch 导出 ONNX 所必需的，因为 ONNX 需要了解模型的输入结构
            dummy_input = torch.randn(*input_size)
            
            # 导出模型
            torch.onnx.export(
                model, # 待导出的 PyTorch 模型
                dummy_input, # 示例输入数据，用于推断模型结构
                filepath, # 输出文件路径
                export_params=True, # 是否导出模型参数（权重），通常设为 True
                opset_version=11, # 使用 ONNX 的操作符版本（v11 支持大多数常见操作）
                do_constant_folding=True, # 是否进行常量折叠优化（提前计算可确定的节点）
                input_names=['input'], # 给输入张量命名
                output_names=['output'], # 给输出张量命名
                dynamic_axes={             # 设置动态轴，允许批大小（batch size）变化
                    'input': {0: 'batch_size'},
                    'output': {0: 'batch_size'}
            }
        )
            
            print(f"模型已导出为ONNX格式: {filepath}")
            print(f"输入形状: {input_size}")
            print(f"输出形状: (batch_size, 10)")

