        @staticmethod
        def visualize_distribution(train_loader, val_loader, test_loader):
            """可视化数据集分布"""
            def count_labels(loader):
                """统计数据集中每个标签的数量"""
                all_labels = []
                for _, labels in loader:
                    all_labels.extend(labels.numpy())
                '''
                _ 表示忽略图像数据（因为我们只关心标签）
                labels 是当前批次的标签张量
                使用 .extend() 而不是 .append() 是为了将每个标签单独加入列表（避免嵌套结构）
                '''
                unique, counts = np.unique(all_labels, return_counts=True)
                '''
                np.unique()：找出所有不重复的标签值（即类别编号），并返回其出现次数。
                return_counts=True：同时返回每个唯一值的计数。
                '''
                return unique, counts
            

            '''
            调用 count_labels() 分别统计三个数据集的标签分布
            train_unique: 训练集的类别编号
            train_counts: 每个类别的样本数
            '''
            train_unique, train_counts = count_labels(train_loader)
            val_unique, val_counts = count_labels(val_loader)
            test_unique, test_counts = count_labels(test_loader)

            # 创建DataFrame,用于构建结构化表格，可以用于后续分析或导出为 CSV 文件
            df_train = pd.DataFrame({
                '数字': train_unique,
                '训练集': train_counts,
                '验证集': val_counts,
                '测试集': test_counts
            })

            # 绘制堆叠柱状图
            fig, axes = plt.subplots(1, 2, figsize=(14, 6))
            '''
            fig 是 Figure 对象（整个图形窗口/画布）,最高层级的容器
            1 行 × 2 列 → 左右两个子图
            figsize=(14, 6)：设置图像大小为宽 14 英寸、高 6 英寸
            '''
            
            # 子图1：各数据集分布
            x = np.arange(10)
            width = 0.25

            '''
            x - width, x, x + width 实现了三组柱子并排显示
            这不是“堆叠”图（stacked bar），而是“分组柱状图”（grouped bar）。真正的堆叠图会把多个值叠加在同一位置。
            '''
            axes[0].bar(x - width, train_counts, width, label='训练集', alpha=0.8)
            axes[0].bar(x, val_counts, width, label='验证集', alpha=0.8)
            axes[0].bar(x + width, test_counts, width, label='测试集', alpha=0.8)
            
            axes[0].set_xlabel('数字', fontsize=12)
            axes[0].set_ylabel('样本数量', fontsize=12)
            axes[0].set_title('各数据集数字分布', fontsize=14, fontweight='bold')
            axes[0].set_xticks(x) # 设置 X 轴刻度位置
            axes[0].set_xticklabels([str(i) for i in range(10)]) # 设置 X 轴刻度标签（0~9）
            axes[0].legend() # 显示图例
            axes[0].grid(True, alpha=0.3, axis='y') # 添加浅灰色 Y 轴网格线，增强可读性

            # 子图2：占比饼图
            total_train = sum(train_counts)
            train_percentages = [count/total_train*100 for count in train_counts]  # 使用列表推导式将每个类别的样本数转换为百分比
            
            '''
            使用 Matplotlib 内置的 Set3 颜色映射（适合分类数据）
            colors：返回一个包含 10 种不同颜色的数组，用于区分不同类别
            '''
            colors = plt.cm.Set3(np.arange(10)/10)

            '''
            wedges: 扇形本身（可用作动画或高亮）
            texts: 外部标签文本
            autotexts: 内部百分比文本
            '''
            wedges, texts, autotexts = axes[1].pie(
                train_percentages,  # 每个扇形的大小（百分比）
                labels=[str(i) for i in range(10)], # 扇形外侧的文字标签（"0", "1", ..., "9"）
                colors=colors,
                autopct='%1.1f%%', # 在扇形内部显示百分比数值（保留一位小数）
                startangle=90 # 从顶部开始绘制第一个扇形（使图表更美观）
            )
            
            axes[1].set_title('训练集数字分布比例', fontsize=14, fontweight='bold')

            # 美化饼图
            for autotext in autotexts:
                autotext.set_color('white')
                autotext.set_fontweight('bold')
            
            plt.tight_layout() # 自动调整子图间距，防止重叠
            plt.show()

            # 打印统计信息
            print("\n数据集统计信息:")
            print(df_train.to_string(index=False))
            print(f"\n训练集总数: {total_train}")
            print(f"验证集总数: {sum(val_counts)}")
            print(f"测试集总数: {sum(test_counts)}")

            # 检查类别平衡性
            train_std = np.std(train_counts)
            train_mean = np.mean(train_counts)
            imbalance_ratio = train_std / train_mean
            
            print(f"\n类别平衡性分析:")
            print(f"  各类别平均样本数: {train_mean:.1f}")  # 每个类别的平均样本数
            print(f"  样本数标准差: {train_std:.1f}") # 样本数的标准差（衡量波动程度）
            print(f"  不平衡比率: {imbalance_ratio:.3f}") # 不平衡比率（越小表示越均衡）
            print(f"  结论: {'类别较平衡' if imbalance_ratio < 0.3 else '类别不平衡'}") # 经验法则：当标准差小于均值的 30% 时，可认为数据基本均衡


        @staticmethod
