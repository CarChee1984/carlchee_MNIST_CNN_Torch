    def analyze_model_complexity(model, input_size=(1, 28, 28)):
        """分析模型复杂度"""
        print("\n" + "="*60)
        print("模型复杂度分析")
        print("="*60)
    
        # 手动计算每层的输出形状和参数量
        print("逐层分析:")
        print("-"*80)
        print(f"{'层类型':<20} {'输出形状':<20} {'参数量':<15} {'计算量(MACs)':<15}")
        print("-"*80)
    
        total_params = 0
        total_macs = 0
    
        # 模拟前向传播来获取各层输出形状
        x = torch.randn(1, *input_size).to(device)
    
        # 分析特征提取部分
        for name, layer in model.features.named_children():
            if isinstance(layer, nn.Conv2d):
                # 计算输出形状
                h_out = (x.shape[2] + 2*layer.padding[0] - layer.dilation[0] * 
                        (layer.kernel_size[0] - 1) - 1) // layer.stride[0] + 1
                w_out = (x.shape[3] + 2*layer.padding[1] - layer.dilation[1] * 
                        (layer.kernel_size[1] - 1) - 1) // layer.stride[1] + 1
            
                # 计算参数量
                params = (layer.in_channels * layer.out_channels * 
                        layer.kernel_size[0] * layer.kernel_size[1])
                if layer.bias is not None:
                    params += layer.out_channels
            
                # 计算计算量（MACs：乘加操作）
                macs = (h_out * w_out * layer.out_channels * layer.in_channels * 
                    layer.kernel_size[0] * layer.kernel_size[1])
            
                print(f"{'卷积层':<20} {f'({x.shape[1]}, {h_out}, {w_out})':<20} "
                    f"{params:,}<15 {macs:,}<15")
            
                total_params += params
                total_macs += macs
            
            elif isinstance(layer, nn.MaxPool2d):
            # 池化层没有参数
                h_out = (x.shape[2] - layer.kernel_size) // layer.stride + 1
                w_out = (x.shape[3] - layer.kernel_size) // layer.stride + 1
                print(f"{'池化层':<20} {f'({x.shape[1]}, {h_out}, {w_out})':<20} "
                    f"{0:<15} {0:<15}")
        
            elif isinstance(layer, nn.BatchNorm2d):
                # BatchNorm参数量：2 * channels
                params = 2 * layer.num_features
                print(f"{'批归一化':<20} {str(x.shape):<20} "
                    f"{params:,}<15 {0:<15}")
                total_params += params
            
            elif isinstance(layer, nn.ReLU):
                print(f"{'激活函数':<20} {str(x.shape):<20} "
                    f"{0:<15} {0:<15}")
        
            # 更新x
            x = layer(x)
    
        # 展平后的尺寸
        flattened_size = x.numel()
        print(f"{'展平':<20} {f'({flattened_size},)':<20} "
            f"{0:<15} {0:<15}")
    
        # 分析分类器部分
        x = x.view(1, -1)  # 展平
        for name, layer in model.classifier.named_children():
            if isinstance(layer, nn.Linear):
                # 全连接层参数量
                params = layer.in_features * layer.out_features
                if layer.bias is not None:
                    params += layer.out_features
            
                # 全连接层计算量
                macs = layer.in_features * layer.out_features
            
                print(f"{'全连接层':<20} {f'({layer.out_features},)':<20} "
                    f"{params:,}<15 {macs:,}<15")
            
                total_params += params
                total_macs += macs
            
            elif isinstance(layer, nn.Dropout):
                print(f"{'Dropout':<20} {str(x.shape):<20} "
                    f"{0:<15} {0:<15}")
                
            elif isinstance(layer, nn.ReLU):
                print(f"{'激活函数':<20} {str(x.shape):<20} "
                    f"{0:<15} {0:<15}")
        
            x = layer(x)
    
        print("-"*80)
        print(f"{'总计':<20} {'-':<20} "
            f"{total_params:,}<15 {total_macs:,}<15")
    
        # 转换为更方便的单位
        total_macs_g = total_macs / 1e9  # Giga MACs
    
        print(f"\n复杂度总结:")
        print(f"  总参数量: {total_params:,}")
        print(f"  总计算量: {total_macs_g:.2f} GMACs")
        print(f"  模型大小: {total_params * 4 / (1024*1024):.2f} MB (float32)")
    
        # 与简单模型的比较
        print(f"\n与简单模型的比较:")
        print(f"  Logistic回归参数量: {28*28*10 + 10:,} (比CNN多{total_params/(28*28*10 + 10):.1f}倍)")
        print(f"  全连接神经网络(1隐藏层): {28*28*128 + 128*10 + 128 + 10:,} (比CNN多{total_params/(28*28*128 + 128*10 + 128 + 10):.1f}倍)")
    
        return total_params, total_macs

    # 分析模型复杂度
