    class DigitRecognizerAPI:
        """手写数字识别API"""
        
        def __init__(self, model_path='digit_recognizer_production.pt', device='cpu'):
            self.device = device
            
            # 加载模型
            self.model = DigitRecognizerCNN().to(device)
            self.model.load_state_dict(torch.load(model_path, map_location=device))
            self.model.eval()
            
            # 数据预处理（与训练时一致）
            self.transform = transforms.Compose([
                transforms.ToTensor(), # 将输入的PIL图像或numpy数组转换为PyTorch张量（Tensor），并自动将像素值归一化到[0, 1]（原像素值范围[0, 255]）
                transforms.Normalize((0.1307,), (0.3081,)) # 用指定的均值(0.1307,)和标准差(0.3081,)对张量进行归一化;这两个数值通常是MNIST数据集（手写数字识别经典数据集）的统计值（训练集计算得到的均值/标准差），目的是让输入数据分布更稳定，提升模型表现
            ])
            
            print(f"数字识别API已初始化，设备: {device}")

        def preprocess_image(self, image):
            """
            预处理图像
            
            参数:
                image: 可以是以下格式之一：
                    1. PIL.Image对象
                    2. numpy数组 (28x28 或 28x28x1 或 28x28x3)
                    3. 文件路径 (str)
            
            返回:
                预处理后的张量
            """
            from PIL import Image # 导入PIL（Python Imaging Library）库的Image模块，用于处理图像（如打开、格式转换）
            import io # 导入io模块（用于处理I/O流)
            
            # 如果输入是文件路径
            if isinstance(image, str):  # 判断输入是否为字符串
                if os.path.exists(image):
                    image = Image.open(image).convert('L')  # 将图像转换为灰度模式（'L'代表8位像素，黑白灰度，每个像素值0-255）
                else:
                    raise FileNotFoundError(f"文件不存在: {image}")
                
            # 如果输入是numpy数组
            elif isinstance(image, np.ndarray):
                # 确保是2D或3D数组,过 image.shape 的维度（2D 或 3D）和通道数，将其转换为灰度的 PIL 图像
                if len(image.shape) == 2:  # 28x28  
                    image = Image.fromarray(image.astype(np.uint8)) # 将数组转为 uint8 类型（图像像素值需是 0-255 的整数），再通过 Image.fromarray 转为 PIL 图像
                elif len(image.shape) == 3:  # 28x28x1 或 28x28x3
                    if image.shape[2] == 1:  # 单通道
                        image = Image.fromarray(image[:,:,0].astype(np.uint8)) # 通过 image[:,:,0] 取第一个通道（去掉冗余的通道维度），转 uint8 后用 Image.fromarray 转 PIL 图像
                    elif image.shape[2] == 3:  # RGB
                        image = Image.fromarray(image.astype(np.uint8)).convert('L') # 转 uint8 后，用 .convert('L') 将 RGB 转为灰度图像（'L' 模式表示灰度，PIL 会自动按权重合并 RGB 通道
                else:
                    raise ValueError(f"不支持的numpy数组形状: {image.shape}")
                
            # 如果输入是字节流
            elif isinstance(image, bytes):
                image = Image.open(io.BytesIO(image)).convert('L') # 用 io.BytesIO(image) 将字节流转为“类文件对象”
            
            # 确保图像是28x28
            if image.size != (28, 28):

                #若尺寸不是 (28, 28)，则用 .resize((28, 28), Image.Resampling.LANCZOS) 缩放为 28×28。其中 LANCZOS 是一种高质量的重采样算法（兰茨奥斯滤波），能较好地保留细节
                image = image.resize((28, 28), Image.Resampling.LANCZOS)
            
            # 应用预处理
            tensor = self.transform(image)
            
            return tensor.unsqueeze(0).to(self.device)  # 添加批次维度
        
        def predict(self, image, return_probabilities=False):
            """
            预测手写数字
            
            参数:
                image: 输入图像（支持多种格式）
                return_probabilities: 是否返回所有数字的概率
                
            返回:
                识别结果
            """
            # 预处理图像
            input_tensor = self.preprocess_image(image)
            
            # 推理
            with torch.no_grad():
                output = self.model(input_tensor) # 使用模型对预处理后的图像进行预测，得到 output
                probabilities = F.softmax(output, dim=1) # 对 output 应用 softmax 函数，得到每个类别的概率 probabilities
                pred = torch.argmax(probabilities, dim=1) # 找到概率最高的类别索引，得到预测结果 pred
                
                confidence = probabilities[0, pred].item() # 获取预测类别的概率值，转换为 Python 标量

            # 准备结果
            result = {
                'digit': pred.item(),
                'confidence': confidence,
                'all_probabilities': probabilities[0].cpu().numpy() if return_probabilities else None
            }
            
            return result
        
        def predict_batch(self, images):
            """批量预测"""
            batch_tensors = []
            
            for image in images:
                tensor = self.preprocess_image(image)
                batch_tensors.append(tensor)
            
            # 合并批次
            batch = torch.cat(batch_tensors, dim=0) # 使用 torch.cat 沿 dim=0（批次维度）拼接列表中的所有张量，将单张图像的张量合并为一个批次张量（例如：若每张图像预处理后是 [1, C, H, W]，合并后变为 [B, C, H, W]，其中 B 是图像数量）
            
            # 推理
            with torch.no_grad():
                outputs = self.model(batch)
                probabilities = F.softmax(outputs, dim=1)
                preds = torch.argmax(probabilities, dim=1)
                confidences = probabilities[torch.arange(len(preds)), preds]
            
            results = []
            for i in range(len(preds)):
                results.append({
                    'digit': preds[i].item(),
                    'confidence': confidences[i].item(),
                    'all_probabilities': probabilities[i].cpu().numpy()
                })
            
            return results
        
