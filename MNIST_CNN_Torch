            '''
            .flatten()：将所有维度展平为一维数组（如 64×1×28×28 → 45152 个像素值）
            images.numpy()：将 PyTorch 张量转换为 NumPy 数组
            '''
            fig, axes = plt.subplots(1, 3, figsize=(15, 4)) 
            '''
            创建一个包含 1 行 × 3 列 的子图布局
            '''

            # 子图1：像素值分布直方图  axes[0].hist(...)直方图绘制
