    class DigitRecognizerCNN(nn.Module):
        """
        手写数字识别CNN模型
        
        设计思路：
        1. 输入：28×28×1的灰度图像
        2. 使用多个卷积层提取特征
        3. 使用池化层降低空间维度
        4. 使用全连接层进行分类
        5. 输出：10个数字的概率分布
        
        架构：
        Conv1 (3x3) → ReLU → BatchNorm → Conv2 (3x3) → ReLU → BatchNorm → MaxPool
        Conv3 (3x3) → ReLU → BatchNorm → Conv4 (3x3) → ReLU → BatchNorm → MaxPool
        Flatten → Dropout → FC1 → ReLU → Dropout → FC2 → ReLU → FC3 (输出)
        """

        def __init__(self, num_classes=10, dropout_rate=0.5): # dropout用于防止过拟合
            super(DigitRecognizerCNN, self).__init__()  # 调用父类初始化，确保模块正确注册子层
            
            # 特征提取部分
            self.features = nn.Sequential(   # 这是一个由多个卷积层、批归一化层、激活函数和池化层组成的特征提取器，分为三个“卷积块”，每个块负责提取不同层次的特征
                # 第一卷积块：提取低级特征（边缘、角点）
                nn.Conv2d(1, 32, kernel_size=3, padding=1),  # 28×28×1 → 28×28×32
                nn.BatchNorm2d(32),  # 批量归一化
                nn.ReLU(),  # ReLU 激活函数引入非线性
                
                nn.Conv2d(32, 32, kernel_size=3, padding=1),  # 28×28×32 → 28×28×32
                nn.BatchNorm2d(32),
                nn.ReLU(),
                nn.MaxPool2d(kernel_size=2, stride=2),        # 28×28×32 → 14×14×32   最大池化MaxPool2将空间尺寸减半

                # 第二卷积块：提取中级特征（纹理、形状）
                nn.Conv2d(32, 64, kernel_size=3, padding=1),  # 14×14×32 → 14×14×64
                nn.BatchNorm2d(64),
                nn.ReLU(),
                
                nn.Conv2d(64, 64, kernel_size=3, padding=1),  # 14×14×64 → 14×14×64
                nn.BatchNorm2d(64),
                nn.ReLU(),
                nn.MaxPool2d(kernel_size=2, stride=2),        # 14×14×64 → 7×7×64

                # 第三卷积块：提取高级特征（部件组合）
                nn.Conv2d(64, 128, kernel_size=3, padding=1), # 7×7×64 → 7×7×128
                nn.BatchNorm2d(128),
                nn.ReLU(),
                
                nn.Conv2d(128, 128, kernel_size=3, padding=1), # 7×7×128 → 7×7×128
                nn.BatchNorm2d(128),
                nn.ReLU(),
            )

            # 全连接层\分类器部分
            self.classifier = nn.Sequential(
                nn.Dropout(dropout_rate),
                nn.Linear(128 * 7 * 7, 256),  # 展平后的大小是128×7×7=6272
                nn.ReLU(),
                nn.Dropout(dropout_rate/2),
                nn.Linear(256, 128),
                nn.ReLU(),
                nn.Linear(128, num_classes)
            )

            # 初始化权重
            self._initialize_weights()

        '''网络初始化权重'''
        def _initialize_weights(self):  
            for m in self.modules():
                if isinstance(m, nn.Conv2d):
                    nn.init.kaiming_normal_(m.weight, mode='fan_out', nonlinearity='relu')
                    if m.bias is not None:
                        nn.init.constant_(m.bias, 0)
                elif isinstance(m, nn.BatchNorm2d):
                    nn.init.constant_(m.weight, 1)
                    nn.init.constant_(m.bias, 0)
                elif isinstance(m, nn.Linear):
                    nn.init.normal_(m.weight, 0, 0.01)
                    nn.init.constant_(m.bias, 0)
        
        def forward(self, x):
            """前向传播"""
            # 特征提取
            x = self.features(x)
            
            # 展平
            x = x.view(x.size(0), -1)
            
            # 分类
            x = self.classifier(x)
            
            return x
        
        def get_feature_maps(self, x, layer_index=None):
            """获取指定层的特征图（用于可视化）"""
            features = []
            
            # 逐层提取特征
            for i, layer in enumerate(self.features):
                x = layer(x)
                if isinstance(layer, nn.Conv2d):
                    features.append(x.detach())
            
            if layer_index is not None:
                return features[layer_index] if layer_index < len(features) else None
            return features
    
