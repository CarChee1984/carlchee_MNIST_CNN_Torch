    class ModelEvaluator:
        """模型评估器"""
    
        def __init__(self, model, device):
            self.model = model  # 将传入的模型保存为实例变量，方便后续调用
            self.device = device
            self.model.eval()  # 设置为评估模式 评估模式下，模型的行为会与训练模式不同（例如：Dropout层不再随机丢弃神经元、BatchNorm层使用整个训练集的均值/方差，确保评估结果稳定可靠）

        def evaluate_on_test(self, test_loader):
            """在测试集上评估模型"""
            print("\n" + "="*60)
            print("测试集评估")
            print("="*60)
            
            test_loss = 0.0
            all_preds = []
            all_labels = []
            all_probabilities = []

            # 使用测试模式
            with torch.no_grad(): #torch.no_grad()禁用梯度计算

                # 每次迭代取出一个批次（batch）的输入数据（inputs）和对应标签（labels）
                for inputs, labels in test_loader:
                    inputs, labels = inputs.to(self.device), labels.to(self.device)
                    
                    # 前向传播
                    outputs = self.model(inputs)  # 将输入数据喂入模型，得到原始输出（logits，未归一化的预测值）
                    probabilities = F.softmax(outputs, dim=1) # 用softmax函数将原始输出转换为概率分布（dim=1表示在类别维度上归一化，使每一行（一个样本）的概率和为1）
                    
                    # 计算损失
                    loss = F.cross_entropy(outputs, labels) # 使用交叉熵损失函数计算当前批次的损失（输入是原始输出outputs和真实标签labels，交叉熵会自动处理logits到概率的转换）
                    test_loss += loss.item() # 累加当前批次的损失值（loss.item()将标量张量转为Python数值）
                    
                    # 获取预测结果
                    _, preds = torch.max(outputs, 1) # 对原始输出outputs，在类别维度（dim=1）取最大值，返回最大值的索引（即预测的类别标签）。这里_忽略最大值本身，只保留预测类别（preds）
                    
                    # 收集所有预测和标签
                    all_preds.extend(preds.cpu().numpy()) # 将当前批次的预测标签移到CPU并转为numpy数组，追加到all_preds列表
                    all_labels.extend(labels.cpu().numpy()) # 将当前批次的真实标签移到CPU并转为numpy数组，追加到all_labels列表
                    all_probabilities.extend(probabilities.cpu().numpy()) # 将当前批次的概率移到CPU并转为numpy数组，追加到all_probabilities列表

                    # 计算平均损失
                    test_loss = test_loss / len(test_loader)
                    
                # 计算准确率
                all_preds = np.array(all_preds) # 将收集的预测标签列表转为numpy数组
                all_labels = np.array(all_labels) # 将收集的真实标签列表转为numpy数组
                accuracy = np.mean(all_preds == all_labels) * 100 # 通过all_preds == all_labels得到布尔数组（正确为True，错误为False），np.mean计算平均值（即正确预测的比例），再乘以100转换为百分比
                
                print(f"测试损失: {test_loss:.4f}")
                print(f"测试准确率: {accuracy:.2f}%")
                
                return {
                    'loss': test_loss,
                    'accuracy': accuracy,
                    'predictions': all_preds,
                    'labels': all_labels,
                    'probabilities': np.array(all_probabilities)
                }
            
        def confusion_matrix_analysis(self, predictions, labels):    # sklearn.metrics.confusion_matrix 是 scikit-learn 库中用于计算分类模型混淆矩阵的函数
            """混淆矩阵分析"""
            print("\n混淆矩阵分析:")
            print("-"*40)
            
            # 计算混淆矩阵
            cm = confusion_matrix(labels, predictions)
            
            # 绘制混淆矩阵
            plt.figure(figsize=(10, 8))

            # 用seaborn的热力图绘制混淆矩阵
            # annot=True：在热力图单元格内显示数值
            # fmt='d'：数值格式为整数（混淆矩阵元素是整数计数）
            sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', 
                    xticklabels=range(10), yticklabels=range(10)) # x轴（预测标签）、y轴（真实标签）的标签设置为0-9（适用于10分类任务，如手写数字识别）
            plt.xlabel('预测标签', fontsize=12)
            plt.ylabel('真实标签', fontsize=12)
            plt.title('混淆矩阵', fontsize=14, fontweight='bold')
            plt.show()

            # 计算每个类别的指标
            print("\n每个数字的详细性能:")
            print("-"*60)
            print(f"{'数字':<8} {'准确率':<10} {'召回率':<10} {'F1分数':<10} {'支持数':<10}")
            print("-"*60)
                
            # 从混淆矩阵计算每个类别的指标
            for i in range(10):
                # 真正例、假正例、假负例
                tp = cm[i, i]
                fp = cm[:, i].sum() - tp
                fn = cm[i, :].sum() - tp
                tn = cm.sum() - tp - fp - fn
                
                # 计算指标
                precision = tp / (tp + fp) if (tp + fp) > 0 else 0 # 精确率
                recall = tp / (tp + fn) if (tp + fn) > 0 else 0 # 召回率
                f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0
                support = cm[i, :].sum()
                accuracy_class = tp / support if support > 0 else 0
                
                print(f"{i:<8} {accuracy_class*100:>7.2f}% {recall*100:>9.2f}% "
                    f"{f1*100:>9.2f}% {support:>10}")
                    
            # 整体分类报告
            print("\n" + "="*60)
            print("详细分类报告:")
            print("="*60)
            
            # scikit-learn 库的classification_report 函数
            report = classification_report(labels, predictions, 
                                        target_names=[str(i) for i in range(10)]) # 类别名列表（这里生成 ['0', '1', ..., '9']，对应10个类别
            print(report)
            
            # 找出最容易混淆的数字对
            confusion_pairs = []  # 存储“实际数字i、被误识别成的数字j、混淆次数”的元组

            # 这部分通过双层循环遍历混淆矩阵（cm 是一个10×10的矩阵，行i代表实际数字，列j代表预测数字，cm[i,j]代表“实际为i却被预测成j”的样本数）
            # 只有实际数字≠预测数字且混淆次数>0的情况，才会被记录为一个“混淆数字对”（元组形式：(实际数字i, 被误识别成的数字j, 混淆次数)
            for i in range(10): # i 遍历0-9（实际数字类别）
                for j in range(10): # j 遍历0-9（预测数字类别）
                    if i != j and cm[i, j] > 0:  # 实际≠预测（混淆场景） + 混淆次数>0（有混淆发生）
                        confusion_pairs.append((i, j, cm[i, j]))  # 存储(i, j, 混淆次数)
                
            # 按混淆次数排序
            # 通过sort方法，以每个元组的第3个元素（x[2]，即“混淆次数”）为关键字，降序排序（reverse=True）
            confusion_pairs.sort(key=lambda x: x[2], reverse=True)
            
            print("\n最容易混淆的数字对（前5个）:")
            for i, j, count in confusion_pairs[:5]:
                print(f"  {i} 被误识别为 {j}: {count} 次")
            
            return cm
            
        def analyze_errors(self, test_loader, predictions, labels, probabilities, num_errors=10):
            """分析错误预测"""
            print("\n" + "="*60)
            print("错误分析")
            print("="*60)
            
            # 找出所有错误预测的索引
            # 使用 np.where 函数筛选出预测结果与真实标签不相等的索引（predictions != labels）
            # [0] 表示获取第一维的索引（因为 np.where 返回的是元组，第一维是满足条件的索引数组）
            error_indices = np.where(predictions != labels)[0] 
            
            if len(error_indices) == 0:
                print("没有发现错误预测！")
                return
            
            print(f"总错误数: {len(error_indices)}")
            print(f"错误率: {len(error_indices)/len(labels)*100:.2f}%")

            # 随机选择一些错误进行可视化
            # 从所有错误索引中随机选择一部分样本（默认 10 个，但如果总错误数不足 10 个，则选择所有错误样本）
            # replace=False表示不放回抽样（避免重复选择同一个错误样本）
            selected_errors = np.random.choice(error_indices, 
                                            size=min(num_errors, len(error_indices)), 
                                            replace=False)
            
            # 可视化错误预测
            fig, axes = plt.subplots(2, 5, figsize=(15, 6))
            axes = axes.ravel()
            
            # 获取原始图像数据（需要重新加载测试集）
            all_images = []
            all_true_labels = []
            with torch.no_grad():
                for inputs, batch_labels in test_loader:
                    all_images.append(inputs.cpu().numpy())
                    all_true_labels.append(batch_labels.cpu().numpy())
            
            all_images = np.concatenate(all_images, axis=0)  # 将 all_images 列表中的所有图像数据沿着第一个轴（即批次轴）拼接成一个大的 NumPy 数组
            all_true_labels = np.concatenate(all_true_labels, axis=0) # 将 all_true_labels 列表中的所有标签沿着第一个轴拼接成一个大的 NumPy 数组

            # enumerate 是 Python 中的一个内置函数，用于在遍历可迭代对象（如列表、元组等）时，同时获取元素的索引和值
            # 如果 selected_errors 是一个列表 [1, 2, 3]，那么 enumerate(selected_errors) 会产生 (0, 1)、(1, 2) 和 (2, 3)
            for idx, error_idx in enumerate(selected_errors):
                if idx >= 10:  # 只显示前10个
                    break
                    
                image = all_images[error_idx].squeeze() # squeeze() 方法去除多余的维度（例如，将形状为 (1, 28, 28) 的图像转换为 (28, 28)
                true_label = all_true_labels[error_idx]
                pred_label = predictions[error_idx]
                prob = probabilities[error_idx][pred_label] # 获取模型预测当前错误样本为 pred_label 类别的概率
                
                axes[idx].imshow(image, cmap='gray')
                axes[idx].set_title(f'真实: {true_label}, 预测: {pred_label}\n置信度: {prob:.2%}')
                axes[idx].axis('off')

                # 用红色边框标记错误
                for spine in axes[idx].spines.values():
                    spine.set_color('red')
                    spine.set_linewidth(3)
            
            plt.suptitle('错误预测示例', fontsize=16, fontweight='bold', y=1.05)
            plt.tight_layout()
            plt.show()

            # 分析错误类型
            print("\n错误类型分析:")
            error_types = {}
            for i in error_indices:
                true_label = labels[i]
                pred_label = predictions[i]
                key = f"{true_label}→{pred_label}"
                error_types[key] = error_types.get(key, 0) + 1

            
            # 按错误次数排序 sorted() 是 Python 内置的一个函数，用于对可迭代对象（如列表、元组、字典等）进行排序，并返回一个新的已排序的列表
            sorted_errors = sorted(error_types.items(), key=lambda x: x[1], reverse=True)
            
            print(f"{'真实→预测':<12} {'次数':<8} {'占比':<10}")
            print("-"*40)
            for error_type, count in sorted_errors[:10]:  # 显示前10个
                percentage = count / len(error_indices) * 100
                print(f"{error_type:<12} {count:<8} {percentage:>7.2f}%")

        def confidence_analysis(self, probabilities, labels, predictions):
            """置信度分析"""
            print("\n" + "="*60)
            print("置信度分析")
            print("="*60)

            # 计算每个预测的置信度（最高概率）
            confidences = np.max(probabilities, axis=1)  # 沿行（axis=1）取每行最大值，得到一维数组 confidences，长度等于样本数，每个元素是对应样本的“置信度”（最高预测概率）
            
            # 正确预测和错误预测的置信度
            # 比较 predictions（预测标签）和 labels（真实标签），得到布尔数组 correct_mask（形状与 predictions/labels 一致）
            # True 表示“该样本预测正确”，False 表示“预测错误”
            correct_mask = (predictions == labels) 
            correct_confidences = confidences[correct_mask] # 用 correct_mask 筛选 confidences，得到所有预测正确样本的置信度数组
            wrong_confidences = confidences[~correct_mask] # ~correct_mask 是布尔数组的“取反”（True 变 False，反之亦然），筛选出所有预测错误样本的置信度数组
            
            fig, axes = plt.subplots(1, 3, figsize=(15, 5))
    
            # 1. 置信度分布直方图
            axes[0].hist(correct_confidences, bins=30, alpha=0.7, 
                        label='正确预测', color='green')
            axes[0].hist(wrong_confidences, bins=30, alpha=0.7, 
                        label='错误预测', color='red')
            axes[0].set_xlabel('置信度', fontsize=12)
            axes[0].set_ylabel('样本数量', fontsize=12)
            axes[0].set_title('置信度分布', fontsize=14, fontweight='bold')
            axes[0].legend()
            axes[0].grid(True, alpha=0.3)

            # 2. 准确率随置信度的变化
            # np.linspace(0, 1, 11): 生成 [0, 0.1, 0.2, ..., 1.0] 共11个等间距的数，将 [0, 1] 区间划分为 10个子区间（如 [0, 0.1), [0.1, 0.2), ..., [0.9, 1.0]）
            bins = np.linspace(0, 1, 11) 
            bin_centers = (bins[:-1] + bins[1:]) / 2 # 计算每个子区间的中点值（用于后续绘图时的横坐标）
            accuracies = []
            
            for i in range(len(bins)-1):
                mask = (confidences >= bins[i]) & (confidences < bins[i+1]) # 生成布尔掩码，筛选出置信度（confidences 数组）落在当前子区间 [bins[i], bins[i+1]) 内的样本
                if mask.sum() > 0:
                    bin_accuracy = np.mean(predictions[mask] == labels[mask]) * 100
                    accuracies.append(bin_accuracy)
                else:
                    accuracies.append(0)

            axes[1].plot(bin_centers, accuracies, 'b-o', linewidth=2)
            axes[1].set_xlabel('置信度区间', fontsize=12)
            axes[1].set_ylabel('准确率 (%)', fontsize=12)
            axes[1].set_title('准确率 vs 置信度', fontsize=14, fontweight='bold')
            axes[1].grid(True, alpha=0.3)

            # 3. 可靠性图（校准曲线），用于评估模型“预测概率是否可信”
            from sklearn.calibration import calibration_curve # calibration_curve 函数用于计算“校准曲线”的数据点（预测概率的平均值、对应的真实正例率）
            
            # 通过真实标签 labels 和模型预测的类别标签 predictions 的布尔比较，生成一个指示变量（可理解为“预测正确的二元标签”：预测正确为 True（1），错误为 False（0））。这是校准曲线需要的真实二元标签（y_true）
            # confidences：模型预测的概率（置信度），例如二分类任务中预测样本属于正类的概率
            # 将预测概率划分为 10 个区间（“桶”），函数会对每个桶内的数据计算统计量
            # prob_true：每个桶内真实正例的比例（fraction of positives），即该桶内“预测正确”的样本占比
            # prob_pred：每个桶内预测概率的平均值（mean predicted probability）
            
            prob_true, prob_pred = calibration_curve(labels == predictions, 
                                                    confidences, n_bins=10) 
            
            axes[2].plot(prob_pred, prob_true, 's-', linewidth=2, label='模型')
            axes[2].plot([0, 1], [0, 1], 'k--', label='完美校准')
            axes[2].set_xlabel('预测置信度', fontsize=12)
            axes[2].set_ylabel('真实准确率', fontsize=12)
            axes[2].set_title('模型校准曲线', fontsize=14, fontweight='bold')
            axes[2].legend()
            axes[2].grid(True, alpha=0.3)
            
            plt.tight_layout()
            plt.show()

            # 统计信息
            print(f"平均置信度: {confidences.mean():.3f}")
            print(f"正确预测的平均置信度: {correct_confidences.mean():.3f}")
            print(f"错误预测的平均置信度: {wrong_confidences.mean():.3f}")
            
            # 计算预期校准误差（ECE）
            ece = 0
            for i in range(len(bins)-1):
                mask = (confidences >= bins[i]) & (confidences < bins[i+1])
                if mask.sum() > 0:
                    bin_accuracy = np.mean(predictions[mask] == labels[mask])
                    bin_confidence = confidences[mask].mean()
                    bin_weight = mask.sum() / len(confidences)
                    ece += bin_weight * abs(bin_accuracy - bin_confidence)
            
            print(f"预期校准误差（ECE）: {ece:.4f}")

            if ece < 0.02:
                print("✅ 模型校准良好")
            elif ece < 0.05:
                print("⚠️ 模型校准一般")
            else:
                print("❌ 模型校准较差，可能过度自信")

